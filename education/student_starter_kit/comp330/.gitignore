# ============================================================
# ETIS Student Starter Kit .gitignore
# ============================================================

# ------------------------------------------------------------
# Operating System Files
# ------------------------------------------------------------

.DS_Store
Thumbs.db

# ------------------------------------------------------------
# Environment / Secrets
# ------------------------------------------------------------

.env
.env.*

# Never commit secrets
*.pem
*.key
*.crt

# ------------------------------------------------------------
# Python
# ------------------------------------------------------------

__pycache__/
*.py[cod]
*.pyo
*.pyd
.python-version

# Python virtual environments

.venv/
venv/
env/

# Python build artifacts

build/
dist/
*.egg-info/

# ------------------------------------------------------------
# Node.js
# ------------------------------------------------------------

node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ------------------------------------------------------------
# IDE / Editor Files
# ------------------------------------------------------------

.vscode/
.idea/

# ------------------------------------------------------------
# Logs
# ------------------------------------------------------------

*.log

# ------------------------------------------------------------
# Test / Coverage Output
# ------------------------------------------------------------

coverage/
htmlcov/
.coverage

# ------------------------------------------------------------
# Temporary Files
# ------------------------------------------------------------

*.tmp
*.swp

# ------------------------------------------------------------
# ETIS Rule
# ------------------------------------------------------------

# Do NOT ignore engineering evidence.
# The following directories should remain under source control:
#
# docs/
# .github/
# src/
# tests/
#
# Repository evidence is part of the engineering record.